{
  "name": "next-pizza",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "prisma generate && next build --webpack",
    "start": "next start",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:prod": "node scripts/run-with-neon.js prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:reset": "prisma migrate reset",
    "prisma:push": "prisma db push",
    "prisma:preview": "prisma db pull",
    "prisma:seed": "prisma db seed",
    "prisma:seed:prod": "node scripts/run-with-neon.js prisma db seed",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration --pool=forks --poolOptions.forks.maxForks=1",
    "test:ui": "vitest run tests/ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:e2e:regression": "playwright test --grep @regression",
    "test:e2e:a11y": "playwright test --grep @a11y",
    "test:e2e:ui": "playwright test --ui",
    "test:db:up": "docker compose -f docker-compose.test.yml up -d",
    "test:db:down": "docker compose -f docker-compose.test.yml down"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.4",
    "@prisma/client": "^5.11.0",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slider": "^1.1.2",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@types/bcrypt": "^5.0.2",
    "@types/lodash.debounce": "^4.0.9",
    "@types/qs": "^6.9.15",
    "@uploadthing/react": "^6.4.4",
    "axios": "^1.6.8",
    "bcrypt": "^5.1.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "input-otp": "^1.2.3",
    "lodash.debounce": "^4.0.8",
    "lucide-react": "^0.363.0",
    "next": "^16.2.4",
    "next-auth": "^4.24.14",
    "nextjs-toploader": "^1.6.11",
    "pino": "^10.3.1",
    "prisma": "^5.11.0",
    "prisma-extension-pagination": "^0.6.0",
    "qs": "^6.12.1",
    "react": "^18",
    "react-dadata": "^2.23.1",
    "react-dom": "^18",
    "react-hook-form": "^7.51.3",
    "react-hot-toast": "^2.4.1",
    "react-imask": "^7.6.0",
    "react-insta-stories": "^2.6.2",
    "react-use": "^17.5.0",
    "resend": "^3.2.0",
    "stories-react": "^1.1.2",
    "stripe": "^22.0.2",
    "tailwind-merge": "^2.2.2",
    "tailwindcss-animate": "^1.0.7",
    "ts-node": "^10.9.2",
    "uploadthing": "^6.9.0",
    "zod": "^3.22.4",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.7",
    "autoprefixer": "^10.0.1",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8",
    "eslint-config-next": "^16.2.4",
    "ignore-loader": "^0.1.2",
    "jsdom": "^29.1.1",
    "pino-pretty": "^13.1.3",
    "postcss": "^8",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7",
    "vitest-mock-extended": "^4.0.0"
  },
  "overrides": {
    "xml2js": "0.6.2",
    "glob": "^12.0.0",
    "uuid": "^14.0.0",
    "tar": "^7.5.11"
  }
}
