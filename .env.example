# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/pizza"
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST:5432/pizza"

# NextAuth
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# OAuth providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_ID=""
GITHUB_SECRET=""

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Email (Resend)
RESEND_API_KEY="re_..."

# API base URL (used by client-side axios instance)
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# Logging (debug | info | warn | error | silent)
LOG_LEVEL="info"
